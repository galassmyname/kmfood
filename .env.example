# Supabase - récupérer depuis https://supabase.com/dashboard/project/[votre-projet]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (uniquement côté serveur, ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Auth - clé secrète pour les sessions Next.js
NEXTAUTH_SECRET=votre_cle_secrete_aleatoire_ici
NEXTAUTH_URL=http://localhost:3000
